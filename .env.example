# Copy this file to .env and fill in your API keys.
#
# At runtime the app loads .env from the config directory:
#   macOS:   ~/Library/Application Support/com.promptheus.app/.env
#   Linux:   ~/.config/com.promptheus.app/.env
#   Windows: %APPDATA%/com.promptheus.app/.env
#
# For development, place .env in the project root (promptheus-tauri/)
# and it will be picked up by `cargo tauri dev`.

OPENAI_API_KEY=your_api_key_here
