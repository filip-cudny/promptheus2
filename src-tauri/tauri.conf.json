{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram-web/refs/heads/master/nicegram.app/tauri.conf.json",
  "productName": "Promptheus",
  "version": "0.1.0",
  "identifier": "com.promptheus.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Promptheus",
        "width": 800,
        "height": 600,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/default_settings.json"
    ]
  },
  "plugins": {}
}
